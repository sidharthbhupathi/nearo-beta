# Google Gemini API key — used by server.ts for AI post generation
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Server-only admin console & API (never expose in client code)
# Open: https://your-app.onrender.com/admin?key=YOUR_SECRET
ADMIN_API_SECRET="generate_a_long_random_string"

# Firebase Admin SDK — required for delete merchants, KYB, beta config
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON as ONE line (or minified) in Render Environment
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"nearo--visibility",...}'

# Optional: public URL when deployed (not required for local dev)
APP_URL="http://localhost:3000"
